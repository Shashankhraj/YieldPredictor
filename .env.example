# AWS Configuration for SageMaker Integration
# Copy this file to .env.local and fill in your values

# The AWS Region where your SageMaker endpoint is hosted
AWS_REGION=us-east-1

# The name of your SageMaker endpoint
AWS_SAGEMAKER_ENDPOINT=your-endpoint-name

# AWS IAM Credentials with permissions to invoke the SageMaker endpoint
# Ensure these credentials have `sagemaker:InvokeEndpoint` permission
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
